# Скопируй этот файл в .env и заполни значениями.
# .env НИКОГДА не коммитится (см. .gitignore).

# Секрет для подписи сессий. Сгенерируй новый:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=98bb1825fdae09cf67d7f256b413cf93228d043535f34262fa43c3f48c1472e3

# URL подключения к PostgreSQL.
# Локально: postgres://user:password@localhost:5432/messenger
# Railway: берётся из переменных сервиса Railway
DATABASE_URL=postgresql://postgres:VubIgmRDUckYELWdCJdLrJwJQBAFNvTF@postgres.railway.internal:5432/railway

# Режим работы. production = HTTPS-cookie, SSL к БД (rejectUnauthorized=false для Railway)
# development = локальные self-signed сертификаты, HTTP-фоллбэк
NODE_ENV=

# Порт и хост сервера
PORT=3000
HOST=0.0.0.0

# ===== E2EE Key Exchange (внутренний Rust-сервис ①, см. e2ee-key-server/) =====
# URL, на котором слушает key-server. По умолчанию верно для локального запуска.
KEY_SERVER_URL=http://127.0.0.1:7420

# Общий секрет для запросов Node -> key-server. Должен СОВПАДАТЬ со значением
# INTERNAL_SHARED_SECRET в .env самого e2ee-key-server. Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_KEY_SERVER_SECRET=685c55e931a30fb5fac915915d60b15a8fd48dd5c8e98ff7b336a4e3d8f8596e
